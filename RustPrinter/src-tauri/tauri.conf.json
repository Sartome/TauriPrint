{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TauriPrint",
  "version": "1.1.0",
  "identifier": "com.sartome.printmax",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TauriPrint",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' asset:; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' asset: data: blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$PICTURE/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgwRkZBRjY3OTFCNjZCMTcKUldRWGE3YVJaNi8vZ0VTYmxUaldSUHd5Vy9sNTdGczNVZ3hZNU1QbjBvdldzSXhuWTIxQ0ZEZGoK",
      "endpoints": [
        "https://github.com/Sartome/TauriPrint/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "publisher": "Sartome",
    "shortDescription": "L'utilitaire ultime d'impression par lots sans limites.",
    "resources": [
      "resources/SumatraPDF.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}